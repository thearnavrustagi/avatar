# Gemini API (optional, pre-populates the API key field)
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash

# Set to "true" to use hash-based routing and disable PWA (for HuggingFace Spaces)
# VITE_APP_TARGET_HUGGINGFACE_SPACE=

# S3-compatible storage for large asset offloading (optional)
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
# WARP_DRIVE_PUBLIC_BASE=
# STAGE_WEB_WARP_DRIVE_PREFIX=proj-airi/stage-web/main/
